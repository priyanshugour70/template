####################
# Application
####################
APP_ENV=development                  # development | staging | production
SERVER_PORT=8080
SERVER_MODE=debug                    # debug | release (Gin mode)
SERVER_READ_TIMEOUT_SEC=30
SERVER_WRITE_TIMEOUT_SEC=30
SERVER_IDLE_TIMEOUT_SEC=120
SERVER_MAX_HEADER_BYTES=1048576

# Multi-tenant subdomain hosting. Frontends are served at <slug>.<APP_BASE_DOMAIN>
# (e.g. acme.lssgoo.com) and the backend composes tenant-aware URLs (password
# reset, handoff redirects) from this. Use `lvh.me` for local dev — *.lvh.me
# resolves to 127.0.0.1 automatically so you don't need /etc/hosts edits.
APP_BASE_DOMAIN=lvh.me
APP_FRONTEND_SCHEME=http             # http (dev) | https (staging/prod)
APP_FRONTEND_PORT=3000               # appended to host in URLs the backend builds (dev only — leave empty in prod)

####################
# PostgreSQL
####################
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=app_db
POSTGRES_SSLMODE=disable             # disable | require | verify-ca | verify-full
POSTGRES_MAX_OPEN_CONNS=50
POSTGRES_MAX_IDLE_CONNS=25
POSTGRES_CONN_MAX_LIFE_SEC=300

####################
# Redis
####################
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=2                           # cache DB
REDIS_QUEUE_DB=3                     # pub/sub DB

####################
# Auth (JWT) – minimal
####################
AUTH_JWT_SECRET=dev-change-me-in-production-min-32-chars-xx
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_TOKEN_DAYS=7
# Legacy single-URL reset-password fallback. Used only when APP_BASE_DOMAIN is
# unset (rare). Normal flow constructs https://{slug}.{apex}/auth/reset-password.
AUTH_PASSWORD_RESET_BASE_URL=
# How long a one-time SSO handoff token is valid (apex login → tenant subdomain).
# Keep this short — the user is mid-redirect, no human delay is expected.
AUTH_HANDOFF_TTL_SECONDS=60

####################
# CORS
####################
# Explicit allow-list (comma-separated). For wildcard subdomain hosting, leave
# this with only your dev origins and set CORS_ALLOWED_APEX instead.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://lvh.me:3000
# When set, requests from the apex (https://APEX) and every subdomain
# (https://*.APEX) are allowed automatically. Dev convenience: when this is
# `lvh.me` or `localhost`, http schemes are also allowed.
CORS_ALLOWED_APEX=lvh.me

####################
# SMTP – optional (no-op sender if Host/Username empty)
####################
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=App

####################
# S3 / AWS – PDF storage + file uploads
####################
# Credentials use the standard AWS SDK env-var names so IAM roles /
# instance profiles keep working in production. Locally, set the key + secret
# here; in EC2/EKS leave them blank and grant the role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ASSETS_S3_REGION=ap-south-1
ASSETS_S3_BUCKET=
ASSETS_S3_KEY_PREFIX=uploads/
ASSETS_S3_PUBLIC_BASE_URL=
ASSETS_PRESIGN_TTL_SECONDS=900

####################
# Developer keys – external partners (optional)
####################
DEVELOPER_API_KEY_PEPPER=
