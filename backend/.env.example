####################
# Application
####################
APP_ENV=development                  # development | staging | production
SERVER_PORT=8080
SERVER_MODE=debug                    # debug | release (Gin mode)
SERVER_READ_TIMEOUT_SEC=30
SERVER_WRITE_TIMEOUT_SEC=30
SERVER_IDLE_TIMEOUT_SEC=120
SERVER_MAX_HEADER_BYTES=1048576

####################
# PostgreSQL
####################
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=app_db
POSTGRES_SSLMODE=disable             # disable | require | verify-ca | verify-full
POSTGRES_MAX_OPEN_CONNS=50
POSTGRES_MAX_IDLE_CONNS=25
POSTGRES_CONN_MAX_LIFE_SEC=300

####################
# Redis
####################
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=2                           # cache DB
REDIS_QUEUE_DB=3                     # pub/sub DB

####################
# Auth (JWT) – minimal
####################
AUTH_JWT_SECRET=dev-change-me-in-production-min-32-chars-xx
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_TOKEN_DAYS=7
AUTH_PASSWORD_RESET_BASE_URL=http://localhost:3000/reset-password

####################
# CORS
####################
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

####################
# SMTP – optional (no-op sender if Host/Username empty)
####################
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=App

####################
# S3 assets – optional
####################
ASSETS_S3_REGION=
ASSETS_S3_BUCKET=
ASSETS_S3_KEY_PREFIX=uploads/
ASSETS_S3_PUBLIC_BASE_URL=
ASSETS_PRESIGN_TTL_SECONDS=900

####################
# Developer keys – external partners (optional)
####################
DEVELOPER_API_KEY_PEPPER=
